# LangChain Practice - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# OpenAI API Configuration
# Get your key from: https://platform.openai.com/api-keys
# ============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================================================
# Anthropic Claude API Configuration (Optional)
# Get your key from: https://console.anthropic.com/
# ============================================================================
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============================================================================
# Hugging Face API Configuration (Optional)
# Get your token from: https://huggingface.co/settings/tokens
# ============================================================================
HUGGINGFACEHUB_API_TOKEN=your-huggingface-token-here
HF_INFERENCE_ENDPOINT=your-inference-endpoint-here

# ============================================================================
# LangChain Tracing and Monitoring (Optional)
# Enable for debugging and monitoring your chains
# ============================================================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key-here

# ============================================================================
# Project-Specific Settings
# ============================================================================
ENVIRONMENT=development
DEBUG=true
